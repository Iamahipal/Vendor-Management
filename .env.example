# ============================================================
# AI ART DIRECTOR — all keys are OPTIONAL. Configure any ONE of
# them (or several — the app automatically fails over from one
# provider to the next if a request fails or is rate-limited).
# Copy this file to `.env.local` and fill in your key(s).
# ============================================================

# NVIDIA Build (free credits): https://build.nvidia.com -> pick a model -> Get API Key
NVIDIA_API_KEY=""
# Optional override, defaults to meta/llama-3.3-70b-instruct
NVIDIA_MODEL=""

# OpenRouter (free-tier models): https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Optional override, defaults to meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=""

# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optional override, defaults to gemini-2.5-flash
GEMINI_MODEL=""

# Which providers to try, in order. Defaults to nvidia,openrouter,gemini
AI_PROVIDER_ORDER=""

# APP_URL: The URL where this app is hosted (used for OpenRouter attribution
# headers and self-referential links). Defaults to http://localhost:3000
APP_URL=""
